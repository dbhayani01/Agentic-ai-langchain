APP_NAME=AI Customer Support Assistant
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/support_ai
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=["http://localhost:5173"]

# OpenAI-compatible provider settings (Groq defaults)
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant

# Backward compatible aliases still supported by config parser:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# GROQ_API_KEY=
# GROQ_BASE_URL=
# GROQ_MODEL=

RATE_LIMIT_PER_MINUTE=60
VITE_API_BASE_URL=http://localhost:8000/api/v1
